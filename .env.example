# ── Configuration Base44 (Cloud + Auth) ──
# Récupérez ces valeurs depuis votre projet Base44
EXPO_PUBLIC_BASE44_APP_ID=votre_app_id
EXPO_PUBLIC_BASE44_FUNCTIONS_VERSION=votre_version
EXPO_PUBLIC_BASE44_APP_BASE_URL=https://votre-app.base44.app

# Sans ces variables, l'app fonctionne en mode hors-ligne (AsyncStorage uniquement).
# Avec ces variables, l'app synchronise avec le cloud et supporte Google + OTP.
